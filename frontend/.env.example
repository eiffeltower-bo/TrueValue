# Optional overrides. Defaults are relative paths (/api/v1 and /admin) that
# Vite's dev proxy forwards to the backend (see vite.config.ts).
# Only set these if you're serving the SPA without that proxy (e.g. a prod build).
#VITE_API_BASE_URL=http://localhost:8000/api/v1
#VITE_ADMIN_BASE_URL=http://localhost:8000/admin

# Where Vite's dev proxy points. Override if your backend is not on localhost:8000.
#BACKEND_URL=http://127.0.0.1:8000
